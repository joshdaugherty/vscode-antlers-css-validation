{
  "name": "antlers-css-validation",
  "displayName": "Antlers CSS Validation",
  "description": "CSS validation for .antlers.html that treats {{ ... }} template expressions as valid inside <style> blocks",
  "version": "0.1.0",
  "publisher": "joshdaugherty",
  "license": "MIT",
  "author": {
    "name": "Josh Daugherty",
    "url": "https://github.com/joshdaugherty"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joshdaugherty/vscode-antlers-css-validation.git"
  },
  "homepage": "https://github.com/joshdaugherty/vscode-antlers-css-validation#readme",
  "bugs": {
    "url": "https://github.com/joshdaugherty/vscode-antlers-css-validation/issues"
  },
  "keywords": [
    "antlers",
    "statamic",
    "css",
    "vscode",
    "validation",
    "linter"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "antlers",
        "aliases": [
          "Antlers",
          "Statamic Antlers"
        ],
        "extensions": [".antlers.html"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "antlers",
        "scopeName": "text.html.antlers",
        "path": "./syntaxes/antlers.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.css": "css"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-css-languageservice": "^6.3.0",
    "vscode-languageserver-textdocument": "^1.0.0"
  }
}
